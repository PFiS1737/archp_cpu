module Splitter (
    instr: input bit<32>,

    opcode: output bit<7>,
    funct3: output bit<3>,
    rd: output bit<5>,
    rs1: output bit<5>,
    imm12: output signed bit<12>,
) {
    always_comb {
        opcode = instr[31:25];
        funct3 = instr[24:22];
        rd = instr[21:17];
        rs1 = instr[16:12];
        imm12 = instr[11:0];
    }
}
