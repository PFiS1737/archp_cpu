module Top (
    clk: input clock,
    rst: input reset,

    top_input_enable: output logic,
    top_input_value: input bit<32>,

    top_output_enable: output logic,
    top_output_value: output bit<32>,
) {
    var pc: u32;
    var pcwe: logic;
    var pcwdata: u32;
    inst PC_: PC ( clk, rst, we: pcwe, wdata: pcwdata, pc );

    let instr: bit<32> = $sv::get_instruction(pc); // @goto ../dpi/Program.sv

    // TODO: remove this
    always_comb {
        if instr == 32'hffff_ffff {
            $finish();
        }
    }

    let opcode: bit<7> = instr[31:25];
    let funct3: bit<3> = instr[24:22];
    let rd: bit<5> = instr[21:17];
    let rs1: bit<5> = instr[16:12];
    let imm12: signed bit<12> = instr[11:0];

    var rfwe: logic;
    var rfoe: logic<2>;
    var wdata: bit<32>;

    var rdata1: bit<32>;
    var rdata2: bit<32>;

    inst RF_: RF (
        clk,
        rst,
        we: rfwe,
        oe: rfoe,
        rd,
        wdata,
        rs1,
        rs2: imm12[4:0],
        rdata1,
        rdata2,
        // TODO: remove this
        top_input_enable,
        top_input_value,
        top_output_enable,
        top_output_value,
    );

    var rfwe_alsu: logic;
    var rfoe_alsu: logic<2>;
    var wdata_alsu: bit<32>;
    inst ALSU_: ALSU (
        opcode,
        imm12,
        rdata1,
        rdata2,
        rfwe: rfwe_alsu,
        rfoe: rfoe_alsu,
        wdata: wdata_alsu,
    );

    var rfwe_uiu: logic;
    var wdata_uiu: bit<32>;
    inst UIU_: UIU (
        opcode,
        funct3,
        rs1,
        imm12,
        pc,
        rfwe: rfwe_uiu,
        wdata: wdata_uiu,
    );

    var rfwe_lsu: logic;
    var rfoe_lsu: logic<2>;
    var wdata_lsu: bit<32>;
    inst LSU_: LSU (
        clk,
        rst,
        opcode,
        rd,
        imm12,
        rdata1,
        rdata2,
        rfwe: rfwe_lsu,
        rfoe: rfoe_lsu,
        wdata: wdata_lsu,
    );

    var rfwe_bjlu: logic;
    var rfoe_bjlu: logic<2>;
    var wdata_bjlu: bit<32>;
    var pcwe_bjlu: logic;
    var pcwdata_bjlu: bit<32>;
    inst BJLU_: BJLU (
        opcode,
        funct3,
        rd,
        rs1,
        imm12,
        rdata1,
        rdata2,
        pc,
        rfwe: rfwe_bjlu,
        rfoe: rfoe_bjlu,
        wdata: wdata_bjlu,
        pcwe: pcwe_bjlu,
        pcwdata: pcwdata_bjlu,
    );

    var rfwe_csu: logic;
    var rfoe_csu: logic<2>;
    var wdata_csu: bit<32>;
    var pcwe_csu: logic;
    var pcwdata_csu: bit<32>;
    inst CSU_: CSU (
        clk,
        rst,
        opcode,
        funct3,
        rs1,
        imm12,
        rdata1,
        pc,
        rfwe: rfwe_csu,
        rfoe: rfoe_csu,
        wdata: wdata_csu,
        pcwe: pcwe_csu,
        pcwdata: pcwdata_csu,
    );

    assign rfwe = rfwe_alsu | rfwe_uiu | rfwe_bjlu | rfwe_lsu | rfwe_csu;
    assign rfoe = rfoe_alsu | rfoe_bjlu | rfoe_lsu | rfoe_csu;
    assign wdata = wdata_alsu | wdata_uiu | wdata_bjlu | wdata_lsu | wdata_csu;

    assign pcwe = pcwe_bjlu | pcwe_csu;
    assign pcwdata = pcwdata_bjlu | pcwdata_csu;

    #[ifdef(TRACE)]
    initial {
        $display("Tracing enabled...");
        $dumpfile("__dump__.fst");
        $dumpvars();
    }
}
